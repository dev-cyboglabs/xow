{
  "appId": "com.xow.play",
  "productName": "XoW Play",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "src/main/**/*",
    "resources/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "mac": {
    "target": {
      "target": "dmg",
      "arch": "universal"
    },
    "icon": "resources/icon.icns",
    "category": "public.app-category.productivity"
  },
  "dmg": {
    "artifactName": "XoW-Play.dmg",
    "title": "XoW Play"
  },
  "win": {
    "target": {
      "target": "portable",
      "arch": "x64"
    },
    "icon": "resources/icon.ico"
  },
  "portable": {
    "artifactName": "XoW-Play.exe"
  },
  "linux": {
    "target": {
      "target": "AppImage",
      "arch": "x64"
    },
    "icon": "resources/icon.png",
    "category": "Utility"
  },
  "appImage": {
    "artifactName": "XoW-Play.AppImage"
  },
  "extraResources": [],
  "asar": true
}
